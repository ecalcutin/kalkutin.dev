{
  "name": "kalkutin.dev",
  "version": "1.0.27",
  "description": "",
  "scripts": {
    "build": "npm run build:client && npm run build:server",
    "build:client": "cross-env NODE_ENV=production webpack --config webpack.client.ts",
    "build:server": "cross-env NODE_ENV=production webpack --config webpack.server.ts",
    "start:dev": "cross-env NODE_ENV=development webpack serve --config webpack.client.ts",
    "start:prod": "cross-env NODE_ENV=production node build/server.js",
    "lint": "eslint --ext .ts ./src",
    "prepare": "husky"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ecalcutin/kalkutin.dev.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/ecalcutin/kalkutin.dev/issues"
  },
  "homepage": "https://github.com/ecalcutin/kalkutin.dev#readme",
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "dependencies": {
    "express": "^5.1.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.1",
    "@types/react": "^19.1.4",
    "@types/react-dom": "^19.1.5",
    "@types/webpack-node-externals": "^3.0.4",
    "copy-webpack-plugin": "^13.0.0",
    "cross-env": "^7.0.3",
    "esbuild-loader": "^4.3.0",
    "eslint": "^9.26.0",
    "eslint-import-resolver-typescript": "^4.3.4",
    "eslint-plugin-import": "^2.31.0",
    "html-webpack-plugin": "^5.6.3",
    "husky": "^9.1.7",
    "lint-staged": "^16.0.0",
    "prettier": "^3.5.3",
    "ts-node": "^10.9.2",
    "typescript-eslint": "^8.32.1",
    "webpack": "^5.99.8",
    "webpack-cli": "^6.0.1",
    "webpack-dev-server": "^5.2.1",
    "webpack-merge": "^6.0.1",
    "webpack-node-externals": "^3.0.0"
  }
}
